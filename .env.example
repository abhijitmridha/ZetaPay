# ============================================================================
# ZetaPay Environment Configuration
# Copy this file to .env and fill in the values for your local setup.
# ============================================================================

# Supabase Authentication
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (PostgreSQL via Drizzle)
DATABASE_URL=postgresql://user:password@localhost:5432/zetapay
DIRECT_URL=postgresql://user:password@localhost:5432/zetapay

# App URL (used for server-side fetches during SSR)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security - generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_encoded_key

# Stellar Network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployer Account (Stellar CLI identity alias used by contract scripts)
STELLAR_SOURCE_ACCOUNT=zetapay-deployer

# Contract IDs (set these after running `yarn contracts:deploy`)
ZETAPAY_VERIFIER_CONTRACT_ID=contract_id_here
ZETAPAY_PAYROLL_CONTRACT_ID=contract_id_here
ZETAPAY_POOL_CONTRACT_ID=contract_id_here

# Token Contracts (Stellar Asset Contract IDs)
# Resolve with: stellar contract id asset --network testnet --asset native
#               stellar contract id asset --network testnet --asset USDC:<issuer>
NEXT_PUBLIC_XLM_TOKEN_CONTRACT=stellar_xlm_contract_id
NEXT_PUBLIC_USDC_TOKEN_CONTRACT=stellar_usdc_contract_id
