# ============================================================================
# ZetaPay - Development environment configuration reference
# Values here are placeholders only. Real values are stored as GitHub
# Environment secrets/variables for the "development" GitHub Environment
# and injected at deploy time - never commit real credentials.
# See docs/ci-cd/secrets.md for where each value comes from.
# ============================================================================

# Supabase Authentication (dev Supabase project)
NEXT_PUBLIC_SUPABASE_URL=your_dev_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_dev_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_dev_supabase_service_role_key

# Database (PostgreSQL via Drizzle) - dev database
DATABASE_URL=postgresql://user:password@dev-db-host:5432/zetapay
DIRECT_URL=postgresql://user:password@dev-db-host:5432/zetapay

# App URL (used for server-side fetches during SSR)
NEXT_PUBLIC_APP_URL=https://dev.zetapay.example.com

# Security - generate with: openssl rand -hex 32 (unique per environment)
TOKEN_ENCRYPTION_KEY=your_dev_32_byte_hex_encoded_key

# Stellar Network - development always targets testnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployer Account (Stellar CLI identity alias used by contract scripts)
STELLAR_SOURCE_ACCOUNT=zetapay-deployer-dev

# Contract IDs (testnet deployment for this environment)
ZETAPAY_VERIFIER_CONTRACT_ID=contract_id_here
ZETAPAY_PAYROLL_CONTRACT_ID=contract_id_here
ZETAPAY_POOL_CONTRACT_ID=contract_id_here

# Token Contracts (Stellar Asset Contract IDs, testnet)
NEXT_PUBLIC_XLM_TOKEN_CONTRACT=stellar_xlm_contract_id
NEXT_PUBLIC_USDC_TOKEN_CONTRACT=stellar_usdc_contract_id
