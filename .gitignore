# =======================================================
# Payroll generated artifacts
# =======================================================

/circuits/payroll/build/*.wtns
/circuits/payroll/build/*.r1cs
/circuits/payroll/build/*.sym
/circuits/payroll/build/*_0000.zkey

# Ignore generated json
/circuits/payroll/build/*.json

# Keep committed artifacts
!/circuits/payroll/build/proof.json
!/circuits/payroll/build/public.json
!/circuits/payroll/build/verification_key.json

# =======================================================
# Shielded Pool generated artifacts
# =======================================================

/circuits/pool/build/*.wtns
/circuits/pool/build/*.r1cs
/circuits/pool/build/*.sym
/circuits/pool/build/*_0000.zkey

# Ignore generated json
/circuits/pool/build/*.json

# Keep committed artifacts
!/circuits/pool/build/deposit_proof.json
!/circuits/pool/build/deposit_public.json
!/circuits/pool/build/deposit_verification_key.json

!/circuits/pool/build/withdraw_proof.json
!/circuits/pool/build/withdraw_public.json
!/circuits/pool/build/withdraw_verification_key.json

